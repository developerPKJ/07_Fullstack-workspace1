		// > DB 에서 INSERT 구문 실행 후 돌아오면 된다!!
		
		// DB INSERT 를 성공했다고 가정
		return "success";
	}
	
	// PUT 요청에 대한 메소드
	@PutMapping("boards/{boardNo}")
	public void updateBoard(@PathVariable int boardNo) {
		
		System.out.println(boardNo);
		
	}
	
	
	
	
	
	
	
}
